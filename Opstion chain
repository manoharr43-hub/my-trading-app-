# 4. RESULTS DISPLAY
# =============================
results = []

with st.spinner("AI విశ్లేషిస్తోంది..."):
    for stock in stocks:
        current_price = yf.Ticker(stock).fast_info['last_price']
        signal = get_ai_prediction(stock)
        results.append({"Stock": stock, "Price (₹)": round(current_price, 2), "AI Signal": signal})

# DataFrame Display
df_res = pd.DataFrame(results)

def apply_color(val):
    color = 'green' if 'BUY' in val else 'red'
    return f'color: {color}; font-weight: bold'

st.table(df_res.style.applymap(apply_color, subset=['AI Signal']))

